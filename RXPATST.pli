   IF PAR ^= '' THEN
     GET STRING(PAR) LIST(M,N);
   ELSE DO;
     M = 1;
     N = 79;
   END;

   IF QTEMPLATE = '"' THEN
     Q = '''';
   ELSE
     Q = '"';

   DO I = M TO N;
     IF T(I) ^= '' THEN DO;
       PUT SKIP EDIT('---',I,'---') (A,F(IWIDE(I)),A);
       PUT SKIP EDIT('S=',Q,S(I),Q) (A,A,A,A);

       STRING = S(I);
       TEMPLATE = T(I);
       CALL RXPARSE(STRING, TEMPLATE, TOKENS, MISC);

       PUT SKIP EDIT('T=',Q,T(I),Q) (A,A,A,A);

       IF RETCODE ^= 0 THEN DO;
         IF XTEMPLATE ^= 0 THEN
           PUT SKIP EDIT(RETCODE,':','!') (F(2),A,X(XTEMPLATE - 1),A);
       END;

       ELSE
         DO J = 1 TO XTOKENS;
           IF ITOK(J) > 0 THEN DO;
             PUT SKIP EDIT(VARPREFIX,J,'=',Q,TOKENS(J),Q)
               (A,F(IWIDE(J)),A,A,A,A);
             IF LENGTH(TOKENS(J)) = LENGTH(E(I,J)) &
                TOKENS(J) = E(I,J) THEN
               PUT SKIP EDIT('OK') (A);
             ELSE
               PUT SKIP EDIT('!!=',Q,E(I,J),Q)
                 (A,A,A,A);
           END;
         END;

       PUT SKIP EDIT(' ') (A);
     END;
   END;

   RETURN ;


   IWIDE: PROC(F) RETURNS(FIXED BIN(15));

     DCL F FIXED BIN(15);
     DCL (I,J) FIXED BIN(15);

     J = F;
     DO I = 0 BY 1 WHILE(J ^= 0);
       J = J / 10;
     END;
     IF F < 0 THEN
       I = I + 1;

     RETURN(I);

   END;


   ITOK: PROC(N) RETURNS(FIXED BIN(15));

     DCL N FIXED BIN(15);
     DCL T CHAR(2);

     SUBSTR(T,1,1) = VARPREFIX;
     SUBSTR(T,2,1) = SUBSTR('123456789',N,1);

     RETURN(INDEX(TEMPLATE,T));

   END;

 END;
