 RXPATST: PROC(PAR) OPTIONS(MAIN);

   DCL PAR CHAR(100) VAR;
   DCL RXPARSE ENTRY RETURNS(FIXED BIN(31));
   DCL (I,J,M,N) FIXED BIN(15);
   DCL Q CHAR(1);

   DCL STRING CHAR(55) VAR ;
   DCL TEMPLATE CHAR(55) VAR ;
   DCL TOKENS(6) CHAR(55) VAR ;
   DCL 1 MISC,
         2 NTOKENS FIXED BIN(15) INIT(6),
         2 RETCODE FIXED BIN(15),
         2 XTOKENS FIXED BIN(15),
         2 XTEMPLATE FIXED BIN(15),
         2 QTEMPLATE CHAR(1) INIT('"'),
         2 VARPREFIX CHAR(1) INIT('?');

